{
  "name": "@kids-play/game",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --env-file-if-exists=../../.env ../../node_modules/vite/bin/vite.js --host 127.0.0.1 --port ${GAME_PORT:-3001} --strictPort",
    "build": "tsc -p tsconfig.json --noEmit && node --env-file-if-exists=../../.env ../../node_modules/vite/bin/vite.js build",
    "preview": "node --env-file-if-exists=../../.env ../../node_modules/vite/bin/vite.js preview --host 127.0.0.1 --port 3001",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@kids-play/shared": "0.1.0",
    "@vitejs/plugin-react": "^4.3.4",
    "vite": "^6.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "typescript": "^5.7.3"
  }
}
